game (
	name "Silent Hill - Origins (Japan)"
	serial "SLKA-25422"
	description "Silent Hill Origins is a prequel in Konami's most successful survival horror series. Players take the role of trucker Travis Grady, who comes to the famously fog-laden town for a routine delivery. Origins features the debut of the 'Cineractive' system, designed to intensify feelings of isolation and uncertainty in the player. Through a 'quick-time event'-style mechanic, gamers react to cut-scenes by entering button sequences at key moments, to respond to their current situation with a counter-attack or quick dodge, for example."
	developer "Climax Group"
	publisher "Konami"
	releaseyear "2008"
	releasemonth "3"
	releaseday "28"
	users "1"
	genre "Survival Horror"
	rom (
