game (
	name "Smash Court Pro Tournament (Japan)"
	serial "SLPS-20171"
	description "High stakes professional tennis hits the courts of the PlayStation 2, complete with big name athletes and top-notch competition. Choose from eight players of international renown -- Andre Agassi, Lindsay Davenport, Martina Hingis, Yevgeny Kafelnikov, Anna Kournikova, Patrick Rafter, Pete Sampras, or Monica Seles -- and lead your chosen pro to victory at Wimbledon, the U.S. Open, and other world famous contests."
	developer "Namco"
	publisher "Namco"
	releaseyear "2002"
	releasemonth "2"
	releaseday "7"
	users "2"
	genre "Sports"
	rom (
