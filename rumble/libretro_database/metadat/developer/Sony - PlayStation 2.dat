game (
	name "Princess Princess (Japan)"
	serial "SLPS-25694"
	description "Princess Princess is the title of a fictional series written and illustrated by Japanese author Mikiyo Tsuda about the lives of three high school boys and the school they attend. The series is contained within multiple media pieces which began as a manga first serialized in the manga magazine Wings starting in 2002. After the first manga series ended, a sequel entitled Princess Princess + started serialization in the same magazine in May 2006, and finished in January 2007. An anime has since been adapted from the manga and began airing in Japan on April 5, 2006, produced by the Japanese animation studio, Studio Deen. A live action adaptation called Princess Princess D aired in Japan from June 28, 2006 to September 13, 2006. Finally, a visual novel video game for the PlayStation 2 based on the series was released on October 26, 2006 in Japan."
	developer "Marvelous Entertainment"
	publisher "Marvelous Entertainment"
	releaseyear "2006"
	releasemonth "10"
	releaseday "26"
	users "1"
	genre "Adventure"
	rom (
		serial "SLPS-25694"
		name "Princess Princess (Japan).cue"
	)
)

