)

game (
	name "Sly 3 - Honor Among Thieves (Japan)"
	serial "SCKA-20063"
	description "Developer Sucker Punch continues its PS2 run with this third stealth-action platformer starring the affable scofflaw raccoon, Sly Cooper. As in earlier games, players will guide Sly and his crew through a series of missions that reward tactical planning, patient surveillance, and precise platform jumping. The story begins after the events of Sly Cooper 2, as Sly coaxes Bentley back to the team. It may be harder to convince Murray back into action, as he suffers from self-doubt after an accident in a previous adventure."
	developer "Sucker Punch Productions"
	publisher "Sony"
	releaseyear "2005"
