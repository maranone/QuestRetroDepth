game (
	name "Shakugan no Shana (Japan)"
	serial "SLPS-25599"
	description "Shakugan no Shana, also known simply as Shana, is a Japanese light novel series written by Yashichiro Takahashi with illustrations by Noizi Ito. ASCII Media Works published 26 novels from November 2002 to November 2012 under their Dengeki Bunko imprint. The story focuses on Yuji Sakai, a high school boy who inadvertently becomes involved in an age-old conflict between forces of balance and imbalance in existence. In the process, he befriends a fighter for the balancing force and names her 'Shana'. The series incorporates fantasy and slice of life elements into its tale."
	developer "Vridge"
	publisher "Media Works"
	releaseyear "2006"
	releasemonth "3"
	releaseday "23"
	users "1"
	genre "Adventure"
