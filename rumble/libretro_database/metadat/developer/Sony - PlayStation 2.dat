game (
	name "Shuffle! On the Stage (Japan)"
	serial "SLPM-66134"
	description "Shuffle! is a Japanese visual novel developed by Navel. It was originally released as an adult game for Microsoft Windows on January 30, 2004. It was subsequently followed by an all-ages release for the PlayStation 2 (PS2) and an expanded adult release for Windows. The Windows version was localized in English by MangaGamer in 2009. The gameplay in Shuffle! follows a branching plot line which offers pre-determined scenarios and courses of interaction and focuses on the appeal of the female main characters. Shuffle! has been re-made into an expanded version called Shuffle! Essence+. It has expanded routes for the original five main heroines as well as new routes for six other characters. Shuffle! also has three spin-off sequels: Tick! Tack! , Really? Really! and Shuffle! Love Rainbow."
	developer "Omegavision"
	publisher "Kadokawa Shoten"
	releaseyear "2005"
	releasemonth "10"
	releaseday "20"
	users "1"
	genre "Adventure"
	rom (
		serial "SLPM-66134"
		name "Shuffle On the Stage (Japan).cue"
	)
)

