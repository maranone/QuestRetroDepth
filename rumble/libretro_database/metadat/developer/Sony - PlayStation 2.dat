	)
)

game (
	name "Th3 Plan (Europe)"
	serial "SLES-53965"
	description "In this action/stealth game, the player can control up to 3 characters at the same time. The screen is split in three parts and each of the characters can also be controlled by a different human player. Using the Hi-tech equipment from any of the seven team members, the player can combine their actions to reach his goal in smart ways. For instance, it is possible to talk to a guard to distract him with one character and open a forbidden door with one of the two remaining characters..."
	developer "Eko Software"
