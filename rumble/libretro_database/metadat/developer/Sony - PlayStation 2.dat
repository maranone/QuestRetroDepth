game (
	name "Rozen Maiden - Duellwalzer (Japan)"
	serial "SLPM-66357"
	description "Rozen Maiden is a manga series by Peach-Pit. It was serialized in Monthly Comic Birz between the September 2002 and July 2007 issues. The individual chapters were collected and released into eight tankobon volumes by Gentosha. The eight volumes were localized to North America by Tokyopop between March 2003 and June 2007. The story follows Jun Sakurada, a middle school student who withdrew from society after suffering persecutions from his classmates. Following his withdrawal, he is chosen to become the master to a Rozen Maiden named Shinku. Rozen Maidens are seven sentient bisque dolls who compete against each other to become a perfect doll dubbed as Alice."
	developer "Taito Corporation"
	publisher "Taito Corporation"
	releaseyear "2006"
	releasemonth "4"
	releaseday "27"
	users "1"
	genre "Action"
