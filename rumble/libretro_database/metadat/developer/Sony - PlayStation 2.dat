game (
	name "Star Wars - La Guerra dei Cloni (Europe)"
	serial "SLES-50829"
	description "Star Wars: The Clone Wars is a vehicular combat game that takes place after the conclusion of Star Wars: Episode II. Players will choose from a variety of crafts before embarking on 16 missions set on six different planets. Mission objectives range from defending vessels from oncoming fire to escorting convoys until they safely reach their destination. Some missions are playable on foot, but the majority take place within the vehicle as it skims across the planet's surface. Along the way are defensive and offensive power-ups to pick up as well as secret bonus items."
	developer "Pandemic Studios"
	publisher "Lucasarts"
	releaseyear "2002"
	releasemonth "12"
	releaseday "11"
	users "2"
	genre "Action"
	rom (
		serial "SLES-50829"
		name "Star Wars - La Guerra dei Cloni (Europe).cue"
	)
)

